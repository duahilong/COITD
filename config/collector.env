#!/usr/bin/env bash

# CloudflareSpeedTest 基础
CFST_BIN="./bin/CloudflareST"
CFST_WORKDIR="./bin"
RESULT_FILE="./data/result.csv"
IP_VERSION="4"

# 输入治理
PRIMARY_TEST_URL="https://cf.xiu2.xyz/url"
FALLBACK_TEST_URLS="https://speed.cloudflare.com/__down?bytes=5000000"
COLO_ALLOWLIST="HKG,SJC,LAX"

# 第一阶段参数
CFST_ARGS="-httping -cfcolo HKG,SJC,LAX -url https://cf.xiu2.xyz/url -dn 20 -dt 10 -tl 250 -sl 0 -o ./data/result.csv"

# 运行控制
LOCK_FILE="./data/run.lock"
LOCK_META_FILE="./data/run.lock.meta.json"
STATE_FILE="./data/state.json"
HISTORY_FILE="./data/history.jsonl"
LOG_FILE="./logs/app.log"
RUN_TIMEOUT_SEC="900"
HISTORY_MAX_LINES="100000"
LOG_ROTATE_SIZE_MB="100"
SCHEDULE_INTERVAL_MIN="20"

SCRIPT_VERSION="1.0.0"
SCHEMA_VERSION="1.0"
