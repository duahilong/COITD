#!/usr/bin/env bash

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# CloudflareSpeedTest 基础
CFST_BIN="${BASE_DIR}/bin/CloudflareST"
CFST_WORKDIR="${BASE_DIR}/bin"
RESULT_FILE="${BASE_DIR}/data/result.csv"
IP_VERSION="4" # 4 或 6

# 输入治理
PRIMARY_TEST_URL="https://speed.cloudflare.com/__down?bytes=20000000"
FALLBACK_TEST_URLS="https://speed.cloudflare.com/__down?bytes=5000000"
COLO_ALLOWLIST="HKG,SJC,LAX"

# CFST 参数基线（第一阶段：地区 + 下载测速）
CFST_ARGS="-httping -cfcolo HKG,SJC,LAX -url ${PRIMARY_TEST_URL} -dn 20 -dt 10 -tl 250 -sl 1 -o ${RESULT_FILE}"

# 运行控制
LOCK_FILE="${BASE_DIR}/data/run.lock"
LOCK_META_FILE="${BASE_DIR}/data/run.lock.meta.json"
STATE_FILE="${BASE_DIR}/data/state.json"
HISTORY_FILE="${BASE_DIR}/data/history.jsonl"
LOG_FILE="${BASE_DIR}/logs/app.log"
RUN_TIMEOUT_SEC=900
HISTORY_MAX_LINES=100000
LOG_ROTATE_SIZE_MB=100
SCHEDULE_INTERVAL_MIN=20

# 版本与契约
SCRIPT_VERSION="1.0.0"
SCHEMA_VERSION="1.0"
